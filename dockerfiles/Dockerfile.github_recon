FROM python:3.11-slim
RUN apt-get update -qq && apt-get install -y --no-install-recommends git ca-certificates \
    && rm -rf /var/lib/apt/lists/*
RUN git clone --depth 1 https://github.com/gwen001/github-search.git /app/github-search
RUN pip install --no-cache-dir -r /app/github-search/requirements.txt
RUN mkdir /output
WORKDIR /app/github-search
ENTRYPOINT ["python3", "/app/github-search/github-endpoints.py"]

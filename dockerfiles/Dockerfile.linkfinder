FROM python:3.9-slim
RUN apt-get update -qq && apt-get install -y --no-install-recommends git ca-certificates \
    && rm -rf /var/lib/apt/lists/*
RUN git clone --depth 1 https://github.com/GerbenJavado/LinkFinder.git /app/linkfinder
RUN pip install --no-cache-dir -r /app/linkfinder/requirements.txt
RUN mkdir /output
WORKDIR /app/linkfinder
ENTRYPOINT ["python3", "linkfinder.py"]
